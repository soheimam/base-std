# Copy to .env (gitignored) and fill in. The Makefile sources .env for the
# smoke recipes; script/smoke/config.py reads these values.

# --- Required ---
# JSON-RPC endpoint the smoketest sends real txs to.
RPC_URL=""
# Funded deployer key (signs all setup/admin txs).
DEPLOYER_PK=""
# Second actor key (recipient / non-admin paths).
USER2_PK=""

# --- Optional: deployer faucet top-up ---
# When both are set, the deployer is funded if its balance is below
# FAUCET_MIN_ETHER (default 0.02). Leave blank to disable.
FAUCET_URL=""
FAUCET_NETWORK=""
